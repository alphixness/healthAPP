# AI API Keys
EXPO_PUBLIC_DEEPSEEK_API_KEY=your-deepseek-api-key
EXPO_PUBLIC_BAIDU_API_KEY=your-baidu-api-key
EXPO_PUBLIC_BAIDU_SECRET_KEY=your-baidu-secret-key
EXPO_PUBLIC_QWEN_API_KEY=your-qwen-api-key

# Cloudflare Worker (API proxy for DeepSeek)
# Deploy workers/api-proxy first, then set the URL here
EXPO_PUBLIC_API_WORKER_URL=https://your-worker.your-name.workers.dev

# Supabase (optional - for cloud sync)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Sentry (optional - for error monitoring)
EXPO_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/your-project
