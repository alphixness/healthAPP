PORT=3001
JWT_SECRET=your-jwt-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
DATABASE_PATH=./data/healthapp.db

# Payment webhook signing
PAYMENT_WEBHOOK_SECRET=your-payment-webhook-secret

# Email (SMTP) — optional, verification emails fall back to console.log when unset
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-pass
SMTP_FROM=noreply@yourdomain.com

# CORS allowed origins (comma-separated, supports * wildcard)
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# Log level: debug | info | warn | error
LOG_LEVEL=info

# WeChat login — configure for production, leave empty for mock in dev
WECHAT_APP_ID=your-wechat-app-id
WECHAT_APP_SECRET=your-wechat-app-secret
